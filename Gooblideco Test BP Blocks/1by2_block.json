{
    "format_version": "1.21.70",
    "minecraft:block": {
        "description": {
            "identifier": "gooblideco:1by2_block",
            "menu_category": {
                "category": "items"
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": [
                        "minecraft:cardinal_direction"
                    ]
                }
            },
            "states": {
                "goobli:block_states": [
                    "bottom",
                    "top"
                ]
            }
        },
        "permutations": [
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            180,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            0,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            90,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            -90,
                            0
                        ]
                    }
                }
            }
        ],
        "components": {
            "minecraft:display_name": "1 by 2 Block",
            "minecraft:geometry": {
                "identifier": "geometry.1by2_block_model",
                "bone_visibility": {
                    "top": "q.block_state('goobli:block_states') == 'top'",
                    "bottom": "q.block_state('goobli:block_states') == 'bottom'"
                }
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "1by2_block_texture",
                    "render_method": "opaque"
                }
            },
            "minecraft:item_visual": {
                "geometry": "geometry.1by2_block_item",
                "material_instances": {
                    "*": {
                        "texture": "1by2_block_texture"
                    }
                }
            },
            "minecraft:collision_box": {
                "origin": [-8, 0, 6],
                "size": [16, 16, 2]
            },
            "minecraft:selection_box": {
                "origin": [-8, 0, 6],
                "size": [16, 16, 2]
            },
            "minecraft:light_dampening": 0,
            "minecraft:light_emission": 0,
            "minecraft:custom_components": [
                "goobli:place1x2_v"
            ]
        }
    }
}
